# Quoridor Server Configuration
# Copy this file to .env and fill in real values

# MongoDB connection URL
# Get from MongoDB Atlas: https://cloud.mongodb.com/
MONGO_URI=mongodb://localhost:27017/quoridor

# Session secret (generate a random 64+ char string for production!)
# Example: openssl rand -hex 32
SESSION_SECRET=change_me_to_random_secret

# Server port
PORT=3000

# Environment (development/production)
NODE_ENV=development

# Allowed origins for CORS (comma-separated, for production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Sentry DSN (error tracking) — get from https://sentry.io
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxx.ingest.de.sentry.io/xxxxxx

# Socket.IO Admin UI credentials (optional, dev debug)
# Открыть https://admin.socket.io и ввести эти данные
# SOCKET_ADMIN_USERNAME=admin
# SOCKET_ADMIN_PASSWORD=your_password

# Bot matchmaking fallback
BOTS_ENABLED=false
BOT_RANKED_ENABLED=false
BOT_FALLBACK_MIN_WAIT_MS=15000
BOT_FALLBACK_MAX_WAIT_MS=25000
BOT_MAX_ACTIVE_GAMES=15
BOT_MOVE_MIN_DELAY_MS=800
BOT_MOVE_MAX_DELAY_MS=2500
BOT_MAX_RECENT_MATCHES=3
BOT_RECENT_WINDOW_MS=3600000

# Resend API key for password reset emails (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=onboarding@resend.dev
# SITE_URL=https://playquor.org
